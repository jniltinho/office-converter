# =============================================================================
# office-converter - Environment Configuration Example
# =============================================================================
#
# Copy this file to `.env` in the project root and edit the values as needed.
# You can also pass these variables directly when running Docker.
#
# Usage examples:
#   docker run --env-file .env -p 8080:8080 office-converter
#   docker compose --env-file .env up
#   OFFICE_PORT=9000 make docker-run
#
# All variables are optional. Defaults are shown below and match the
# behavior in entrypoint.sh and the application code.
#
# These variables are respected in both:
#   - Docker containers (via entrypoint.sh)
#   - Local development (`make serve` or `php -S api/router.php`)
#
# =============================================================================

# -----------------------------------------------------------------------------
# Server Binding
# -----------------------------------------------------------------------------
# The address and port the FrankenPHP server will listen on.

OFFICE_HOST=0.0.0.0
# Interface to bind to.
# Use "127.0.0.1" or "localhost" to listen only on the loopback interface.
# Default: 0.0.0.0 (all interfaces)

OFFICE_PORT=8080
# TCP port the HTTP server listens on.
# Default: 8080

# -----------------------------------------------------------------------------
# Conversion Limits
# -----------------------------------------------------------------------------
# Controls how LibreOffice conversions are executed and protected.

OFFICE_CONVERSION_TIMEOUT=60s
# Maximum wall-clock time allowed for a single conversion (after acquiring a
# slot). Uses coreutils `timeout` internally.
# Accepts values like: 30s, 2m, 1h
# Default: 60s

OFFICE_MAX_UPLOAD_SIZE=104857600
# Maximum allowed upload size in **bytes**.
# This is enforced both by PHP (upload_max_filesize / post_max_size) and
# by the application before processing.
# Default: 104857600 (100 MiB)

OFFICE_MAX_CONCURRENT_CONVERSIONS=2
# Maximum number of simultaneous LibreOffice conversions.
# Implemented via flock-based slots in /tmp to work reliably under multiple
# FrankenPHP workers or php-fpm processes.
# Default: 2

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Derived PHP settings (applied automatically via php.ini fragment):
#     upload_max_filesize   ≈ OFFICE_MAX_UPLOAD_SIZE (rounded up to MiB)
#     post_max_size         = upload_max_filesize + 2 MiB
#     memory_limit          = 256M
#     max_execution_time    = 0 (unlimited for long conversions)
#
# - Access logs are always written to stdout in JSON format (visible with
#   `docker logs`). There is currently no environment variable to disable them.
#
# - LibreOffice runs in isolated temporary profiles per conversion to avoid
#   "instance already running" errors.
#
# - For production, consider setting tighter limits according to your
#   available CPU/memory and expected load.
