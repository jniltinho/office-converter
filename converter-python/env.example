# =============================================================================
# office-converter - Environment Configuration Example
# =============================================================================
#
# Copy this file to `.env` in the project root and edit the values as needed.
# You can also pass these variables directly when running Docker.
#
# Usage examples:
#   docker run --env-file .env -p 8080:8080 office-converter
#   docker compose --env-file .env up
#   OFFICE_PORT=9000 make docker-run
#
# All variables are optional. Defaults are shown below and match the
# behavior in entrypoint.sh and the application code.
#
# These variables are respected in both:
#   - Docker containers (via entrypoint.sh → uvicorn)
#   - Local development (`make serve` or `python3 -m uvicorn app.main:app`)
#
# =============================================================================

# -----------------------------------------------------------------------------
# Server Binding
# -----------------------------------------------------------------------------
# The address and port uvicorn will listen on.

OFFICE_HOST=0.0.0.0
# Interface to bind to.
# Use "127.0.0.1" or "localhost" to listen only on the loopback interface.
# Default: 0.0.0.0 (all interfaces)

OFFICE_PORT=8080
# TCP port the HTTP server listens on.
# Default: 8080

# -----------------------------------------------------------------------------
# Conversion Limits
# -----------------------------------------------------------------------------
# Controls how LibreOffice conversions are executed and protected.

OFFICE_CONVERSION_TIMEOUT=60s
# Maximum wall-clock time allowed for a single conversion (after acquiring a
# slot). Uses coreutils `timeout` internally with a 5-second SIGKILL grace.
# Accepts values like: 30s, 2m, 1h
# Default: 60s

OFFICE_MAX_UPLOAD_SIZE=104857600
# Maximum allowed upload size in **bytes**.
# Enforced by FastAPI middleware before the request body is read.
# Default: 104857600 (100 MiB)

OFFICE_MAX_CONCURRENT_CONVERSIONS=2
# Maximum number of simultaneous LibreOffice conversions.
# Implemented via asyncio.Semaphore within the single uvicorn worker process.
# The entrypoint starts uvicorn with --workers 1, so this is a global cap.
# Default: 2

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Each conversion runs soffice in an isolated temporary profile directory
#   (/tmp/lo-profile-<random>) to avoid "instance already running" errors.
#   The profile is deleted after the conversion completes.
#
# - If all conversion slots are busy, the server waits up to 30 seconds for
#   one to become free, then returns HTTP 503.
#
# - Access logs are written to stderr by uvicorn (visible with `docker logs`).
#
# - For production, consider tighter limits based on available CPU/memory
#   and expected load.
